<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             xmlns:fa="clr-namespace:UraniumUI.Icons.FontAwesome;assembly=UraniumUI.Icons.FontAwesome"
             xmlns:input="clr-namespace:InputKit.Shared.Controls;assembly=InputKit.Maui"
             xmlns:controls="clr-namespace:Plugin.MauiMTAdmob.Controls;assembly=Plugin.MauiMTAdmob"
             xmlns:validation="clr-namespace:InputKit.Shared.Validations;assembly=InputKit.Maui"
             xmlns:pr="clr-namespace:MPowerKit.ProgressRing;assembly=MPowerKit.ProgressRing"
             x:Class="InstaLoaderMaui.MainPage">

    <!-- TOOLBAR -->
    <ContentPage.ToolbarItems>
        <!-- UPGRADE -->
        <ToolbarItem x:Name="upgrade_item"
                 Text="Upgrade"
                 Clicked="OnUpgradeClicked"
                 IsEnabled="True">
            <ToolbarItem.IconImageSource>
                <FontImageSource x:Name="upgrade_fontimagesource"
                 FontFamily="FASolid" 
                 Color="{AppThemeBinding Dark={StaticResource PointEight}, Light={StaticResource DarkPointEight}}"  
                 Glyph="{x:Static fa:Solid.Gem}"/>
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
        <ToolbarItem x:Name="upgrade_secondary_item"
             Order="Secondary"
             Text="Upgrade"
             Clicked="OnUpgradeClicked" />
        
        <!-- RATE -->
        <ToolbarItem x:Name="rate_item"
             Order="Secondary"
             Text="Rate"
             Clicked="OnRateClicked" />
        <!-- UPGRADE
        <ToolbarItem x:Name="upgrade_secondary_item"
             Order="Secondary"
             Text="Upgrade"
             Clicked="OnUpgradeClicked"/>-->
        
        <!-- PRIVACY -->
        <ToolbarItem x:Name="privacy_item"
             Order="Secondary"
             Text="Privacy"
             Clicked="OnPrivacyPolicyClicked" />
        <!-- ABOUT -->
        <ToolbarItem x:Name="about_item"
             Order="Secondary"
             Text="About"
             Clicked="OnAboutClicked" />
        <!-- HELP -->
        <ToolbarItem x:Name="help_item"
             Order="Secondary"
             Text="Help"
             Clicked="OnHelpClicked" />
    </ContentPage.ToolbarItems>

    <AbsoluteLayout>
        <ScrollView AbsoluteLayout.LayoutBounds="0,0,1,1"
                AbsoluteLayout.LayoutFlags="PositionProportional,SizeProportional">
            <VerticalStackLayout Padding="20,20,20,0" Spacing="20">
                <!-- TEXTFIELD -->
                <material:TextField x:Name="main_textfield"
                            Title="Paste Link…"
                            TitleColor="{AppThemeBinding Light={StaticResource DarkPointEight}, Dark={StaticResource PointEight}}"
                            AllowClear="True"
                            ClearButtonVisibility="WhileEditing"
                            TextChanged="OnTextChanged"
                            Completed="OnTextCompleted">
                    <validation:RegexValidation Pattern="^$|(?:instagram\.com\/)" Message="Please copy an Instagram link" />
                    <!-- PASTE BUTTON -->
                    <material:TextField.Attachments>
                        <material:ButtonView>
                            <ImageButton x:Name="paste_button"
                                Clicked="OnPasteClicked"
                                HeightRequest="32"
                                WidthRequest="32"
                                Margin="0,0,8,0">
                                <ImageButton.Source>
                                    <FontImageSource FontFamily="FASolid" Color="{AppThemeBinding Dark={StaticResource PointEight}, Light={StaticResource DarkPointEight}}"  Glyph="{x:Static fa:Solid.BoltLightning}"/>
                                </ImageButton.Source>
                            </ImageButton>
                        </material:ButtonView>
                    </material:TextField.Attachments>
                </material:TextField>

                <!-- PREVIEW -->
                <AbsoluteLayout x:Name="preview_layout">
                    <!-- BORDER -->
                    <Frame x:Name="preview_frame"
                        BorderColor="{AppThemeBinding Dark={StaticResource PointEight}, Light={StaticResource DarkPointEight}}"
                        BackgroundColor="{StaticResource PointOh}"
                        CornerRadius="10"
                        Padding="-10"
                        ZIndex="1"
                        AbsoluteLayout.LayoutBounds="0,0,1,360"
                        AbsoluteLayout.LayoutFlags="PositionProportional,WidthProportional">
                        <VerticalStackLayout>
                            <!-- THUMBNAIL -->
                            <Image x:Name="preview_img"
                                Source="{Binding MThumbnailUrl}"
                                BackgroundColor="{StaticResource PointOh}"
                                Aspect="AspectFill"
                                ZIndex="1"
                                Opacity="0.0"/>
                            <ScrollView HorizontalScrollBarVisibility="Never"
                                        HeightRequest="380">
                                <Grid>
                                    <WebView x:Name="preview_webview"
                                    IsVisible="False"/>
                                </Grid>
                            </ScrollView>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- PROGRESS -->
                    <VerticalStackLayout AbsoluteLayout.LayoutBounds="0.5,0.5,1,100"
                        AbsoluteLayout.LayoutFlags="PositionProportional,WidthProportional">
                        <!-- RING -->
                        <pr:ProgressRing x:Name="progress_ring"
                             HeightRequest="100"
                             Progress="0"
                             IsIndeterminate="True"
                             Smooth="True"
                             WidthRequest="100"
                             Margin="10"
                             StrokeLineCap="Square"
                             Color="{StaticResource Primary}" 
                             Thickness="4"
                             AbsoluteLayout.LayoutBounds="0.5,0.5,100,25"
                             AbsoluteLayout.LayoutFlags="PositionProportional"
                             Opacity="0.0"/>
                        <!-- MESSAGE -->
                        <Label x:Name="progress_label"
                            WidthRequest="200"
                            Text="{Binding MMessageProgress}"
                            FontSize="Small"
                            TextColor="{AppThemeBinding Dark={StaticResource White}, Light={StaticResource Black}}"
                            HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                    
                </AbsoluteLayout>

                <!-- DOWNLOADER -->
                <AbsoluteLayout>
                    <!-- FRAME -->
                    <Frame x:Name="downloader_frame"
                        BorderColor="{AppThemeBinding Dark={StaticResource PointEight}, Light={StaticResource DarkPointEight}}"
                        BackgroundColor="{StaticResource PointOh}"
                        CornerRadius="10"
                        ZIndex="1"
                        Opacity="0"
                        AbsoluteLayout.LayoutBounds="0,0,1,90"
                        AbsoluteLayout.LayoutFlags="PositionProportional,WidthProportional">
                        <StackLayout Orientation="Horizontal"
                            Spacing="10">
                            <StackLayout VerticalOptions="Center">
                                <!-- TITLE -->
                                <Label x:Name="preview_title"
                                    Text="{Binding MTitle}"
                                    FontSize="Large"
                                    TextColor="{AppThemeBinding Dark={StaticResource White}, Light={StaticResource Black}}"
                                    Margin="5,0,0,0"
                                    WidthRequest="250"
                                    MaxLines="1"
                                    VerticalTextAlignment="Center"
                                    ZIndex="2" />
                            </StackLayout>
                            <!-- DOWNLOAD BUTTON -->
                            <material:ButtonView x:Name="dl_btn"
                                WidthRequest="60"
                                HeightRequest="60"
                                Padding="5"
                                Opacity="0.0">
                                <ImageButton 
                                    Clicked="OnDownloadClicked">
                                    <ImageButton.Source>
                                        <FontImageSource FontFamily="FASolid"        
                                            Glyph="{x:Static fa:Solid.CircleDown}" 
                                            Color="{AppThemeBinding Dark={StaticResource PointEightFive}, Light={StaticResource DarkPointEightFive}}"/>
                                    </ImageButton.Source>
                                </ImageButton>
                            </material:ButtonView>
                            <!-- RING -->
                            <pr:ProgressRing x:Name="progress_ring_dlr"
                                 WidthRequest="50"
                                 HeightRequest="50"
                                 Margin="5"
                                 IsIndeterminate="True"
                                 Smooth="True"
                                 StrokeLineCap="Square"
                                 Color="{AppThemeBinding Dark={StaticResource PointEight}, Light={StaticResource DarkPointEight}}" 
                                 Thickness="2"
                                 Opacity="0.0"
                                 IsVisible="False"/>
                            <!-- FINISH BUTTON -->
                            <material:ButtonView x:Name="finish_btn"
                                WidthRequest="60"
                                HeightRequest="60"
                                Padding="5"
                                Opacity="0.0"
                                IsVisible="False">
                                <ImageButton>
                                    <ImageButton.Source>
                                        <FontImageSource FontFamily="FASolid"
                                            Glyph="{x:Static fa:Solid.CircleCheck}" 
                                            Color="{AppThemeBinding Dark={StaticResource White}, Light={StaticResource Black}}"/>
                                    </ImageButton.Source>
                                </ImageButton>
                            </material:ButtonView>
                        </StackLayout>
                    </Frame>
                </AbsoluteLayout>

                <StackLayout x:Name="banner_ad_container" VerticalOptions="End" HorizontalOptions="Center" IsVisible="{Binding MIsNotGold}">
                    <controls:MTAdView x:Name="banner_ad" AdsId="{Binding MAdmobIdBanner}" AdSize="LargeBanner"/>
                </StackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- POPUP-->
        <AbsoluteLayout 
            x:Name="fragment_layout"
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="PositionProportional,SizeProportional"
            ZIndex="3"
            IsVisible="false">
            <!-- SHADOW -->
            <Image 
                    x:Name="shadow_image"
                    AbsoluteLayout.LayoutBounds="0,0,1,1"
                    AbsoluteLayout.LayoutFlags="PositionProportional,SizeProportional"
                    BackgroundColor="{AppThemeBinding Dark={StaticResource PointSix}, Light={StaticResource DarkPointSix}}" />
            <!-- BORDER -->
            <Frame x:Name="fragment_frame"
                 BorderColor="{AppThemeBinding Dark={StaticResource DarkPointFive}, Light={StaticResource PointFive}}"
                 BackgroundColor="{StaticResource White}"
                 CornerRadius="8"
                 ZIndex="1"
                 Margin="10,60"
                 AbsoluteLayout.LayoutBounds="0,0,1,400"
                 AbsoluteLayout.LayoutFlags="PositionProportional,WidthProportional">
                <Grid>
                    <VerticalStackLayout>
                        <!-- HEADER -->
                        <Grid>
                            <VerticalStackLayout HorizontalOptions="Start">
                                <!-- TITLE -->
                                <Label 
                                     x:Name="fragment_title"
                                     Text="{Binding MFragmentTitle}"
                                     FontFamily="GotuRegular"
                                     FontAttributes="Bold"
                                     FontSize="Large"
                                     TextColor="{StaticResource DarkPointEightFive}"
                                     VerticalTextAlignment="Start"
                                     ZIndex="2" />
                                <!-- SUBTITLE -->
                                <Label 
                                     x:Name="fragment_subtitle"
                                     Text="{Binding MFragmentSubtitle}"
                                     FontFamily="GotuRegular"
                                     FontSize="Medium"
                                     TextColor="{StaticResource DarkPointEight}"
                                     VerticalTextAlignment="Start"
                                     ZIndex="2" />
                            </VerticalStackLayout>

                        </Grid>

                        <!-- BODY -->
                        <Label 
                             x:Name="fragment_body"
                             Text="{Binding MFragmentBody}"
                             FontFamily="GotuRegular"
                             FontSize="Small"
                             TextColor="{StaticResource DarkPointEight}"
                             Margin="16"
                             VerticalTextAlignment="Start"
                             HorizontalTextAlignment="Start"
                             ZIndex="2"
                             LineHeight="1.5"/>

                    </VerticalStackLayout>

                    <!-- BUTTONS -->
                    <HorizontalStackLayout x:Name="fragment_btn_layout"
                       VerticalOptions="End"
                       HorizontalOptions="Center">
                        <!-- DISMISS -->
                        <material:ButtonView>
                            <Button x:Name="dismiss_button"
                                Clicked="OnCloseClicked"
                                Text="{Binding MFragmentDismiss}"
                                BackgroundColor="{StaticResource DarkPointFive}"
                                FontSize="Small"
                                TextColor="{StaticResource GmaGreenWhite}"
                                HorizontalOptions="Center"/>
                        </material:ButtonView>
                        <!-- POSITIVE -->
                        <material:ButtonView>
                            <Button x:Name="positive_button"
                                Clicked="OnPositiveClicked"
                                Text="{Binding MFragmentPositive}"
                                BackgroundColor="{StaticResource GmaGreenDark}"
                                FontSize="16"
                                TextColor="{StaticResource GmaGreenWhite}"
                                HorizontalOptions="Start"/>
                        </material:ButtonView>
                    </HorizontalStackLayout>
                </Grid>
            </Frame>
        </AbsoluteLayout>
    </AbsoluteLayout>
</ContentPage>


