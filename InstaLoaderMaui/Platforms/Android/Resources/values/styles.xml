<resources>
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowContentTransitions">true</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="AppTheme.Launcher" parent="AppTheme.NoActionBar">
		<!-- item name="android:windowBackground">@drawable/splash_bg</item> -->
    </style>

    <style name="TextAppMain" parent="TextAppearance.AppCompat">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/colorWhite</item>
        <item name="android:textAlignment">viewStart</item>
    </style>
    <style name="TextAppTitle">
        <item name="android:textSize">17sp</item>
        <item name="android:textColor">@color/colorWhite</item>
        <item name="android:textAlignment">viewStart</item>
    </style>

    <style name="TextAppSubtitle">
        <item name="android:textSize">15sp</item>
        <item name="android:textAlignment">viewStart</item>
    </style>

    <style name="TextAppFragTitle" parent="TextAppearance.AppCompat">
        <item name="android:textColor">@color/colorWhite</item>
        <item name="android:textSize">19sp</item>
    </style>
    <style name="TextAppFragBody" parent="TextAppearance.AppCompat">
        <item name="android:textColor">@color/colorWhite</item>
        <item name="android:textSize">16sp</item>
    </style>
    <style name="DialogDrip" parent="@android:style/Theme.Dialog">
        <item name="android:padding">@dimen/spacing_med</item>
        <item name="android:background">@drawable/bg_shadow_rounded_outline</item>
        <item name="android:textAppearance">@style/TextAppFragTitle</item>
        <item name="android:textAlignment">center</item>
        <item name="android:windowAnimationStyle">@style/MvxDialogAnimation</item>
    </style>
    <style name="MvxDialogAnimation">
        <item name="android:windowEnterAnimation">@anim/fade_in</item>
        <item name="android:windowExitAnimation">@anim/fade_out</item>
    </style>
    <style name="ButtonDripGood" parent="@style/Widget.AppCompat.Button.Colored">
        <item name="android:colorButtonNormal">@color/buuDarkShadow</item>
        <item name="android:colorPressedHighlight">@color/buuLightShadow</item>
        <item name="android:radius">@dimen/corner_radius_secondary</item>
    </style>
    <style name="ButtonDripBad" parent="@style/Widget.AppCompat.Button.Colored">
        <item name="android:colorButtonNormal">@color/shadowInverseDark</item>
        <item name="android:colorPressedHighlight">@color/shadowInverseLight</item>
        <item name="android:radius">@dimen/corner_radius_secondary</item>
    </style>

</resources>